generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// A-Frame/Glamping Management Models
// -----------------------------------------------------------------------------

model Unit {
  id              String    @id @default(cuid())
  name            String
  type            String    // e.g., "A-Frame", "Tent", "Cabin"
  capacity        Int
  pricePerNight   Float
  amenities       String[]  // Array of amenities
  photoUrls       String[]  // Array of photo URLs
  promotionalCopy String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bookings        Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  unitId       String
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  guestName    String
  guestEmail   String
  guestPhone   String
  checkIn      DateTime @db.Date
  checkOut     DateTime @db.Date
  status       String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  totalPrice   Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Custom migration will add:
  // EXCLUDE USING gist (
  //   "unitId" WITH =,
  //   daterange("checkIn", "checkOut") WITH &&
  // ) WHERE (status != 'CANCELLED')

  cafeOrders   CafeOrder[]
}

// -----------------------------------------------------------------------------
// NextAuth Models (Standard Prisma Adapter)
// -----------------------------------------------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          String    @default("USER") // 'USER' or 'ADMIN'
  passwordHash  String?   // Added for Credentials provider if needed
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Rosa Swimming Pool Management Models
// -----------------------------------------------------------------------------

model PoolTicket {
  id          String   @id @default(cuid())
  guestName   String
  guestEmail  String
  guestPhone  String
  visitDate   DateTime @db.Date
  adultCount  Int      @default(1)
  childCount  Int      @default(0)
  totalPrice  Float
  status      String   @default("PENDING") // PENDING, PAID, USED, EXPIRED
  qrCode      String   @unique // Unique token for the QR code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Rosa Cafe POS Models
// -----------------------------------------------------------------------------

model CafeItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // e.g., "Makanan", "Snack", "Minuman"
  price       Float
  isAvailable Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  CafeOrderItem[]
}

model CafeOrder {
  id            String   @id @default(cuid())
  bookingId     String?  // Optional: linked to a booking if charged to room
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  
  guestName     String?  // For walk-in customers
  tableNumber   String?
  
  totalAmount   Float
  paymentMethod String   // "CASH", "QRIS", "ROOM_CHARGE"
  status        String   @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         CafeOrderItem[]
}

model CafeOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  itemId      String
  item        CafeItem @relation(fields: [itemId], references: [id])
  
  quantity    Int
  priceAtTime Float    // Store price at the time of order
  subtotal    Float
}
